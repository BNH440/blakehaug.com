---
interface Button {
  src: string;
  alt: string;
  href?: string;
}

const buttons: Button[] = [
  { src: "/assets/buttons/blakeh.gif", alt: "blakeh", href: "#" },
  { src: "/assets/buttons/ocf.png", alt: "hosted by the OCF", href: "https://ocf.berkeley.edu" },
  { src: "/assets/buttons/nixos.png", alt: "powered by NixOS", href: "https://nixos.org" },
  { src: "/assets/buttons/tianchenggu.png", alt: "tianchenggu", href: "https://tianchenggu.org" },
  { src: "/assets/buttons/jaysa.net.png", alt: "jaysa.net", href: "https://jaysa.net" },
  { src: "/assets/buttons/rsang.png", alt: "rsang", href: "https://rsang.me" },
  { src: "/assets/buttons/storce.png", alt: "storce", href: "https://joewang.me" },
  { src: "/assets/buttons/leeleexs.png", alt: "leeleexs", href: "https://leeleexs.carrd.co/" },
];
---

<div class="buddy-box">
  <h2>Buttons</h2>
  <div class="buddy-box-grid">
    {buttons.map((button) =>
      button.href ? (
        <a href={button.href} target="_blank" rel="noopener noreferrer" class="buddy-box-link">
          <img src={button.src} alt={button.alt} width="88" height="31" loading="lazy" />
        </a>
      ) : (
        <img src={button.src} alt={button.alt} width="88" height="31" loading="lazy" class="buddy-box-img" />
      )
    )}
  </div>
  {buttons.length === 0 && (
    <p class="buddy-box-empty">No buttons yet — check back soon!</p>
  )}
</div>
