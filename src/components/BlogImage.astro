---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro:assets";

interface Props {
  /** Imported image source (use `import img from '...'` in your MDX file). */
  src: ImageMetadata;
  /** Alt text describing the image for accessibility. */
  alt: string;
  /** Optional caption displayed below the image. */
  caption?: string;
  /** Max display width in pixels. Defaults to 800. */
  width?: number;
}

const { src, alt, caption, width = 800 } = Astro.props;
---

<figure class="blog-image">
  <Image
    src={src}
    alt={alt}
    width={width}
    densities={[1.5, 2]}
    loading="lazy"
    decoding="async"
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
