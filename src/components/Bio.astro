---
import { Image } from "astro:assets";
import { siteConfig } from "../data/site";
import SocialLinks from "./SocialLinks.astro";
---

<div class="bio">
  <Image src={siteConfig.profileImage} alt={`Photo of ${siteConfig.name}`} width={100} height={100} />
  <div>
    <p>
      {siteConfig.description}
    </p>
    <SocialLinks size={20} />
  </div>
</div>
