---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import BuddyBox from "../components/BuddyBox.astro";
import { siteConfig } from "../data/site";

const title = siteConfig.name;
const description = siteConfig.tagline;
const permalink = Astro.site.href;
---

<BaseLayout title={title} description={description} permalink={permalink} current="">
  <div class="home-container">
    <div class="home-copy">
      <h1>{siteConfig.name}</h1>
      <p>{siteConfig.tagline}</p>
      <p>{siteConfig.description}</p>
      <div class="home-links">
        <a href="/about">About Me</a>
        <a href="/projects">Projects</a>
        <a href="/blog">Blog</a>
      </div>
    </div>

    <div class="hero-image-container">
      <Image class="hero-image" src={siteConfig.profileImage} alt={siteConfig.name} width={300} densities={[1.5, 2]} />
      <SocialLinks size={28} />
    </div>
  </div>

  <BuddyBox />
</BaseLayout>
