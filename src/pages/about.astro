---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { siteConfig } from "../data/site";

const title = "About";
const description = `About ${siteConfig.name}`;
const permalink = `${Astro.site.href}about`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="about">
  <div class="container">
    <h1>About</h1>
    <div class="about-content">
      <div class="about-image">
        <Image src={siteConfig.profileImage} alt={`Photo of ${siteConfig.name}`} width={200} />
      </div>
      <div class="about-text">
        <h3>Hello! 👋</h3>
        <p>{siteConfig.description}</p>
        <p>
          You can contact me at{" "}
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </p>

        <SocialLinks size={22} />
      </div>
    </div>
  </div>
</BaseLayout>
